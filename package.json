{
  "name": "ttmanager",
  "version": "0.1.0",
  "private": true,
  "description": "Windows desktop time planner and task manager",
  "main": "apps/desktop/electron/dist/main.cjs",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:renderer\" \"wait-on http://127.0.0.1:5173 && npm:dev:electron\"",
    "dev:renderer": "vite --host 127.0.0.1",
    "dev:electron": "tsc -p apps/desktop/electron/tsconfig.json && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron .",
    "build": "npm run build:renderer && npm run build:electron && npm run build:go",
    "build:renderer": "vite build",
    "build:electron": "tsc -p apps/desktop/electron/tsconfig.json && node scripts/rename-electron-cjs.cjs",
    "build:go": "go -C core build -o ../apps/desktop/electron/bin/ttmanager-service.exe ./cmd/ttmanager-service",
    "dist": "npm run build && electron-builder",
    "dist:portable": "npm run build && electron-builder --win portable",
    "test": "npm run test:go && npm run test:renderer",
    "test:go": "go -C core test ./...",
    "test:renderer": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@radix-ui/react-context-menu": "^2.2.15",
    "@radix-ui/react-dialog": "^1.1.14",
    "@radix-ui/react-popover": "^1.1.14",
    "@radix-ui/react-select": "^2.2.5",
    "@tanstack/react-query": "^5.83.0",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "date-fns-tz": "^3.2.0",
    "electron-updater": "^6.6.2",
    "framer-motion": "^12.23.6",
    "fuse.js": "^7.1.0",
    "lucide-react": "^0.468.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router-dom": "^7.7.0",
    "tailwind-merge": "^2.6.0",
    "zod": "^3.25.76",
    "zustand": "^5.0.6"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.7.2",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^22.10.5",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.2.0",
    "cross-env": "^7.0.3",
    "electron": "^33.4.11",
    "electron-builder": "^25.1.8",
    "jsdom": "^26.1.0",
    "postcss": "^8.5.11",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.3",
    "vite": "^6.3.5",
    "vitest": "^3.2.4",
    "wait-on": "^8.0.3"
  },
  "build": {
    "appId": "com.local.ttmanager",
    "productName": "TT Manager",
    "directories": {
      "output": "dist-installer"
    },
    "asar": false,
    "files": [
      "apps/desktop/electron/dist/**/*",
      "apps/desktop/renderer/dist/**/*",
      "resources/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "apps/desktop/electron/bin/ttmanager-service.exe",
        "to": "bin/ttmanager-service.exe"
      }
    ],
    "extraMetadata": {
      "main": "apps/desktop/electron/dist/main.cjs",
      "type": "commonjs"
    },
    "win": {
      "icon": "resources/icons/icon.ico",
      "target": [
        "nsis",
        "portable"
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": "always",
      "createStartMenuShortcut": true
    }
  }
}
